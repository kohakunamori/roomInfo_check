# ═══════════════════════════════════════════════════════════════
#  roomInfo_check 配置模板
#  复制为 .env 后至少改 WEB_AUTH_TOKEN，其余可之后在网页里配。
# ═══════════════════════════════════════════════════════════════

# ── 必改 ──────────────────────────────────────────────────────
# 仪表盘访问令牌（登录页 / Bearer）。务必改成随机长串！
WEB_AUTH_TOKEN="change-me-to-a-long-random-token"

# ── 常用（可按需改） ──────────────────────────────────────────
# 邮件/提示里展示的仪表盘地址；有域名时改成公网 URL
WEB_PUBLIC_URL="http://127.0.0.1:3032/"

# 宿主机端口绑定（默认仅本机；局域网可改 0.0.0.0:3032）
WEB_BIND="127.0.0.1:3032"
VNC_BIND="127.0.0.1:3033"
# 与 VNC_BIND 左侧端口一致；本机直连 noVNC 用
VNC_PUBLIC_PORT="3033"

# ── 邮件（也可部署后在网页「设置」里改，授权码不会回显） ────
# 使用邮箱服务商「SMTP 授权码」，不是登录密码
Authorization_code=""
SMTP_SERVER="smtp.163.com"
SMTP_PORT="465"
SMTP_FROM=""
SMTP_FROM_NAME="roominfo"
SMTP_USE_SSL="true"

# ── 监测默认值（网页设置可覆盖） ────────────────────────────
CHECK_INTERVAL_MINUTES="60"
LOW_BALANCE_THRESHOLD="20"
SESSION_ALERT_COOLDOWN_HOURS="12"

# ── 学号密码（可选） ──────────────────────────────────────────
# 正常运行只依赖浏览器登录导出的会话 Cookie；密码仅作兜底自动填表
API_USERNAME=""
API_PASSWORD=""

# ── Docker 镜像（默认已是 GHCR 预构建，免本地 build） ────────
# ROOMINFO_IMAGE="ghcr.io/kohakunamori/roominfo:latest"
# ROOMINFO_AUTH_IMAGE="ghcr.io/kohakunamori/roominfo-auth:latest"
# 本地开发强制构建：ROOMINFO_IMAGE=roominfo:latest

# ── 认证容器（一般不用动） ────────────────────────────────────
# manual = 网页「刷新登录」写触发文件，由 roominfo-auth-ctl 启停
AUTH_MODE="manual"
AUTH_SERVICE_NAME="roominfo-auth"
# 留空：本机浏览器直连 :VNC_PUBLIC_PORT；远程则走同源 /vnc/（需反代）
# 仅当 noVNC 与仪表盘不同源时才填绝对地址
AUTH_NOVNC_URL=""
AUTH_TIMEOUT_SECONDS="900"
AUTH_HOLD_SECONDS="20"

# ── 门户会话（服务器主容器必须 false，compose 已强制） ──────
ONLINE_SESSION_FILE="./data/.uestc_session.json"
ONLINE_BROWSER_REFRESH="false"
ONLINE_REMEMBER_ME="true"

# ── 内部路径（一般不用动） ────────────────────────────────────
DATA_FILE="./data.json"
HISTORY_DB="./data/history.db"
HISTORY_RETAIN_DAYS="90"
WEB_HOST="0.0.0.0"
WEB_PORT="8080"
FLASK_SECRET_KEY=""
TZ="Asia/Shanghai"
